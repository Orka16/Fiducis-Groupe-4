<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>FIDUCIS — Expertise comptable, juridique et conseil RH</title>
<meta name="description" content="Cabinet pluridisciplinaire d'expertise comptable, juridique et conseil RH. Bordeaux, La Rochelle, Bayonne.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400&family=Inter:wght@400;500;600&family=Spline+Sans+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{
  --pine:#14352B; --pine-deep:#0E2620; --ink:#1C2723; --paper:#F5F7F2; --card:#FFFFFF;
  --brass:#B0843C; --brass-dk:#8B6730; --muted:#5B645E; --line:#D5DBD2; --line-dk:#2C3D36;
  --display:"Fraunces",Georgia,"Times New Roman",serif;
  --body:"Inter",system-ui,-apple-system,"Segoe UI",Roboto,sans-serif;
  --mono:"Spline Sans Mono",ui-monospace,Menlo,monospace;
  --maxw:1140px; --pad:clamp(20px,5vw,64px);
}
*{box-sizing:border-box;}
html{scroll-behavior:smooth;}
@media (prefers-reduced-motion:reduce){html{scroll-behavior:auto;} *{animation:none!important;transition:none!important;}}
body{margin:0;font-family:var(--body);color:var(--ink);background:var(--paper);font-size:17px;line-height:1.6;-webkit-font-smoothing:antialiased;}
a{color:inherit;}
.wrap{max-width:var(--maxw);margin:0 auto;padding-inline:var(--pad);}
.eyebrow{font-family:var(--mono);font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:var(--brass-dk);margin:0 0 18px;}
h1,h2,h3{font-family:var(--display);font-weight:400;line-height:1.05;margin:0;}
.lede{font-size:clamp(19px,2.2vw,22px);color:var(--muted);max-width:56ch;}

.nav{position:sticky;top:0;z-index:50;background:color-mix(in srgb,var(--paper) 88%,transparent);backdrop-filter:blur(8px);border-bottom:1px solid var(--line);}
.nav__inner{display:flex;align-items:center;justify-content:space-between;height:66px;}
.brand{font-family:var(--display);font-size:22px;letter-spacing:.02em;text-decoration:none;}
.brand b{color:var(--brass-dk);font-weight:600;}
.nav__links{display:flex;gap:28px;align-items:center;}
.nav__links a{font-size:15px;text-decoration:none;color:var(--ink);}
.nav__links a:hover{color:var(--brass-dk);}
.nav__cta{font-family:var(--body);font-size:14px;text-decoration:none;border:1px solid var(--pine);color:var(--pine);padding:9px 16px;border-radius:2px;}
.nav__cta:hover{background:var(--pine);color:var(--paper);}
.nav__burger{display:none;background:none;border:0;font-size:22px;cursor:pointer;}
@media (max-width:860px){
  .nav__links{display:none;}
  .nav__burger{display:block;}
  .nav__links.open{display:flex;flex-direction:column;align-items:flex-start;gap:16px;position:absolute;top:66px;left:0;right:0;padding:20px var(--pad);background:var(--paper);border-bottom:1px solid var(--line);}
}

.hero{padding:clamp(56px,9vw,110px) 0 clamp(40px,6vw,72px);}
.hero h1{font-size:clamp(38px,6.2vw,76px);letter-spacing:-0.015em;max-width:16ch;}
.hero h1 em{font-style:italic;color:var(--brass-dk);}
.hero .lede{margin-top:26px;}
.hero__actions{margin-top:34px;display:flex;gap:14px;flex-wrap:wrap;}

.btn{font-family:var(--body);font-size:15px;text-decoration:none;display:inline-block;padding:13px 22px;border-radius:2px;cursor:pointer;border:1px solid var(--pine);}
.btn--solid{background:var(--pine);color:var(--paper);}
.btn--solid:hover{background:var(--pine-deep);}
.btn--ghost{background:transparent;color:var(--pine);}
.btn--ghost:hover{background:var(--pine);color:var(--paper);}

.ledger{margin-top:56px;border-top:1px solid var(--line);}
.ledger__row{display:grid;grid-template-columns:1fr auto;align-items:baseline;gap:16px;padding:16px 0;border-bottom:1px solid var(--line);}
.ledger__row span:first-child{color:var(--muted);font-size:15px;}
.ledger__val{font-family:var(--mono);font-size:clamp(18px,2.4vw,24px);color:var(--pine);}

.section{padding:clamp(56px,8vw,96px) 0;}
.section--dark{background:var(--pine);color:var(--paper);}
.section--dark .eyebrow{color:var(--brass);}
.section--dark .lede{color:color-mix(in srgb,var(--paper) 78%,transparent);}
.section__head{max-width:62ch;margin-bottom:48px;}
.section__head h2{font-size:clamp(28px,4vw,44px);letter-spacing:-0.01em;}

.pillars{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--line);border:1px solid var(--line);}
.pillar{background:var(--card);padding:32px 28px 36px;}
.pillar__tag{font-family:var(--mono);font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:var(--brass-dk);}
.pillar h3{font-size:25px;margin:14px 0 12px;}
.pillar p{color:var(--muted);font-size:15.5px;margin:0 0 18px;}
.pillar ul{margin:0;padding-left:18px;color:var(--ink);font-size:15px;}
.pillar li{margin:6px 0;}
@media (max-width:860px){.pillars{grid-template-columns:1fr;}}

.approach{display:grid;grid-template-columns:1fr 1fr;gap:clamp(28px,5vw,72px);align-items:start;}
.approach__list{display:grid;gap:22px;}
.approach__item{border-top:1px solid var(--line-dk);padding-top:18px;}
.approach__item h3{font-size:21px;margin-bottom:8px;color:var(--paper);}
.approach__item p{margin:0;color:color-mix(in srgb,var(--paper) 74%,transparent);font-size:15.5px;}
@media (max-width:800px){.approach{grid-template-columns:1fr;}}

.sites{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;}
.site-card{border:1px solid var(--line);background:var(--card);padding:26px;border-radius:2px;}
.site-card h3{font-size:22px;margin-bottom:6px;}
.site-card .role{font-family:var(--mono);font-size:12px;letter-spacing:.12em;text-transform:uppercase;color:var(--brass-dk);}
.site-card p{color:var(--muted);font-size:15px;margin:12px 0 0;}
@media (max-width:800px){.sites{grid-template-columns:1fr;}}

.panel-grid{display:grid;grid-template-columns:1fr 1fr;gap:clamp(28px,5vw,64px);align-items:start;}
@media (max-width:820px){.panel-grid{grid-template-columns:1fr;}}
.form{background:var(--card);border:1px solid var(--line);border-radius:2px;padding:clamp(24px,4vw,38px);}
.form h3{font-size:28px;margin:10px 0 24px;}
.field{margin-bottom:20px;}
.field label{display:block;font-size:14px;font-weight:600;margin-bottom:7px;color:var(--ink);}
.field input,.field select,.field textarea{width:100%;font-family:var(--body);font-size:16px;color:var(--ink);padding:12px 14px;border:1px solid var(--line);border-radius:2px;background:#fff;}
.field input:focus,.field select:focus,.field textarea:focus{outline:2px solid var(--brass);outline-offset:1px;border-color:var(--brass);}
